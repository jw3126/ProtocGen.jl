#!/bin/sh
# -*- mode: julia -*-
#=
# Self-executing Julia script. The shell exec below is inside a Julia
# multi-line comment (#= ... =#) so Julia ignores it; the shell runs it
# and re-execs julia on this same file.
#
# Dev shim — runs against the live worktree without `Pkg.Apps.add`.
# Both this shim and the Pkg.Apps-installed binary dispatch through
# `ProtocGenJulia.PluginApp.@main`, so the two install paths stay
# in lockstep.
HERE="$(cd "$(dirname "$0")" && pwd)"
# `--compile=min -O0` mirrors the [apps] entry in Project.toml — both
# install paths run with the same flags so timing / behavior match.
exec julia --project="${HERE}/.." --startup-file=no --color=no --compile=min -O0 "$0" "$@"
=#

using ProtocGenJulia

exit(ProtocGenJulia.PluginApp.main(ARGS))
